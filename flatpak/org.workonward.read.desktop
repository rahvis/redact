[Desktop Entry]
Name=WorkOnward Read
GenericName=PDF Redaction Tool
Comment=Redact sensitive information in PDFs and images
Exec=workonward-read %f
Icon=org.workonward.read
Terminal=false
Type=Application
Categories=Office;Utility;Graphics;
MimeType=application/pdf;image/png;image/jpeg;
StartupNotify=true
StartupWMClass=workonward-read
Keywords=pdf;redact;privacy;censor;black;bar;cover;
X-GNOME-UsesNotifications=false
