<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the (currently dormant) notarization path.

  When a paid Apple Developer account becomes available, sign with:

    codesign force deep options runtime \
      entitlements packaging/macos/entitlements.plist \
      sign "Developer ID Application: ..." dist/CoverUP.app

  The hardened runtime blocks unsigned executable memory and library
  loading, which PyInstaller-frozen Python apps (ctypes, bundled dylibs
  such as pdfium) need. These two entitlements relax exactly that.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
