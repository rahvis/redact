# Include font files
recursive-include workonward_read/fonts *.ttf *.otf

# Include app icon assets
recursive-include workonward_read/assets *.png

# Include PyInstaller hooks
recursive-include workonward_read/pyinstaller_hooks *.py

# Include documentation
include README.md
include LICENSE

# Include requirements
include requirements.txt

# Exclude compiled Python files
global-exclude __pycache__
global-exclude *.py[cod]
